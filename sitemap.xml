---
layout: null
permalink: /sitemap.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign sitemap_pages = site.pages | where_exp: "item", "item.layout == 'default'" %}
{% for item in sitemap_pages %}
{% unless item.sitemap == false or item.robots == 'noindex' %}
  <url>
    <loc>{{ item.url | absolute_url | xml_escape }}</loc>
    {% if item.last_modified_at %}<lastmod>{{ item.last_modified_at | date_to_xmlschema }}</lastmod>{% endif %}
  </url>
{% endunless %}
{% endfor %}
</urlset>
